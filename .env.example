# =============================================================================
# CENTINEL — Variáveis de Ambiente
# =============================================================================
# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env no repositório.
#
#   cp .env.example .env
# =============================================================================


# -----------------------------------------------------------------------------
# PostgreSQL (banco de dados do Keycloak)
# -----------------------------------------------------------------------------

# Nome do banco de dados criado automaticamente na primeira inicialização
KC_DB_NAME=keycloak

# Usuário do banco
KC_DB_USER=keycloak

# Senha do banco — use uma senha forte (mínimo 20 caracteres)
KC_DB_PASSWORD=TROQUE_POR_SENHA_FORTE


# -----------------------------------------------------------------------------
# Keycloak (Identity Provider)
# -----------------------------------------------------------------------------

# URL pública do Keycloak — deve corresponder ao hostname configurado
# no Cloudflare Tunnel (ex: auth.seudominio.com.br)
KC_HOSTNAME=auth.seudominio.com.br

# Usuário administrador do console do Keycloak
KC_ADMIN_USER=admin

# Senha do administrador — use uma senha forte e diferente da do banco
KC_ADMIN_PASSWORD=TROQUE_POR_SENHA_FORTE


# -----------------------------------------------------------------------------
# Cloudflare Tunnel
# -----------------------------------------------------------------------------

# Token gerado no dashboard do Cloudflare Zero Trust
# Zero Trust → Networks → Tunnels → seu tunnel → Configure → Token
CF_TUNNEL_TOKEN=COLE_SEU_TOKEN_CLOUDFLARE_AQUI


# -----------------------------------------------------------------------------
# Tailscale (VPN privada)
# -----------------------------------------------------------------------------

# Auth key gerada em: tailscale.com/admin/settings/keys
# Recomendado: gere uma chave reusável e com tag para facilitar o gerenciamento
TS_AUTHKEY=tskey-auth-COLE_SUA_CHAVE_TAILSCALE_AQUI
